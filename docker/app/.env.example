# Из контейнеров api/parsers: хост БД — сервис leads-db (docker/infra), порт 5432.
# На сервере используйте те же учётные данные, что и POSTGRES_* в docker/infra/.env.
DATABASE_URL=postgresql://leads:changeme@leads-db:5432/leads
APP_ENV=development # development | production
PROPRADAR_API_KEY=changeme
PROPRADAR_REPO_ROOT=/srv
MYHOME_CLI_TIMEOUT_SECONDS=3600
MYHOME_API_BASE_URL=https://api-statements.tnet.ge
MYHOME_EMAIL=
MYHOME_PASSWORD=
MYHOME_SESSION_PATH=scripts/myhome_session.json
MYHOME_ENRICH_LIMIT=50
MYHOME_PDF_OUTPUT_DIR=data/myhome_pdf
MYHOME_PDF_PUBLIC_BASE_URL=

