# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=UTC
# Задайте при включении шифрования учётных данных в n8n (не коммитить реальное значение)
# N8N_ENCRYPTION_KEY=

# Metabase (опционально; для embedded H2 по умолчанию доп. переменные не обязательны)
MB_SITE_NAME=PropRadar

# Evolution API (ключ — только через секреты локально, не в репозитории)
AUTHENTICATION_API_KEY=change-me
SERVER_URL=http://localhost:8080
