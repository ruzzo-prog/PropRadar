# Скопируйте в `.env` и подставьте значения локально. Секреты не коммитить.

# PostgreSQL (leads-db, хост-порт 5433)
DATABASE_URL=postgresql://leads:changeme@localhost:5433/leads

# Приложение (заготовки; без реальных ключей в репозитории)
APP_ENV=development

# База HTTP API myhome (не секрет; переопределять при необходимости)
MYHOME_API_BASE_URL=https://api-statements.tnet.ge

# pytest: реальный GET к api-statements (интеграция) — 1 / 0
MYHOME_INTEGRATION=0

# Metabase: scripts/setup_metabase_dashboard.py (пароли не коммитить)
# METABASE_URL=http://localhost:3031
# METABASE_USER=
# METABASE_PASSWORD=
# LEADS_DATABASE_NAME=PropRadar Leads
