# Скопируйте в `.env` и подставьте значения. Секреты не коммитить.
# Профили: детальные шаблоны — `.env.example.local` (хост + БД localhost:5433),
# `.env.example.server` (контейнеры на сервере). Ниже — типичный локальный хост.

# PostgreSQL (leads-db с хоста, порт 5433)
DATABASE_URL=postgresql://leads:changeme@localhost:5433/leads

# Приложение (заготовки; без реальных ключей в репозитории)
APP_ENV=development

# Локальный uvicorn: порт 9000 — `uvicorn api.main:app --reload --host 127.0.0.1 --port 9000`
# Docker API (compose): внутри сети http://api:8000, с хоста http://127.0.0.1:8000

# База HTTP API myhome (не секрет; переопределять при необходимости)
MYHOME_API_BASE_URL=https://api-statements.tnet.ge

# pytest: реальный GET к api-statements (интеграция) — 1 / 0
MYHOME_INTEGRATION=0

# myhome.ge: scripts/myhome_login.py, run_myhome_enricher и контейнер playwright-worker (секреты не коммитить).
# Для docker compose сервиса playwright-worker обязательны для автологина (POST /login) и парсинга телефонов:
MYHOME_EMAIL=user@example.com
MYHOME_PASSWORD=CHANGEME_STRONG_PASSWORD
# MYHOME_SESSION_PATH=scripts/myhome_session.json
# MYHOME_ENRICH_LIMIT=50
# HTTP phone enricher (2captcha + phone/show); секрет только в локальном .env:
# TWOCAPTCHA_API_KEY=
# MYHOME_RECAPTCHA_SITE_KEY=6LeziPEpAAAAAHuR9vWBVCrfklSbWt8zixM4jAbM
# MYHOME_PHONE_HTTP_WORKERS=5
# MYHOME_PHONE_HTTP_ENABLED=true
# MYHOME_PHONE_PLAYWRIGHT_FALLBACK=false
# MYHOME_PDF_OUTPUT_DIR=data/myhome_pdf
# MYHOME_PDF_PUBLIC_BASE_URL=

# Metabase: scripts/setup_metabase_dashboard.py (пароли не коммитить)
# METABASE_URL=http://localhost:3031
# METABASE_USER=
# METABASE_PASSWORD=
# LEADS_DATABASE_NAME=PropRadar Leads

# Evolution API (docker compose profile tools; ключ и URI — только в локальном .env, не в репозитории)
AUTHENTICATION_API_KEY=change-me
# Локально: http://localhost:8080. За reverse-proxy (TLS): https://<ваш-evolution-FQDN>
SERVER_URL=http://localhost:8080

# Evolution API — персистентность в БД (официальный образ evoapicloud/evolution-api, см. doc.evolution-api.com)
# Включить запись состояния в БД (true/false)
DATABASE_ENABLED=true
# Провайдер БД, например: postgresql | mysql (значение без подстановки в compose — задайте в .env)
DATABASE_PROVIDER=postgresql
# URI подключения Evolution API к PostgreSQL.
# Рекомендуемый target в текущем проекте: postgres-кластер leads-db, отдельная схема `evolution_api`.
# Для docker-сети propradar используйте service name: leads-db, порт 5432.
# При внешней БД замените host/user/password/dbname на свои значения (секреты — только в локальном .env).
DATABASE_CONNECTION_URI=postgresql://leads:changeme@leads-db:5432/leads?schema=evolution_api
# Имя клиента в пуле подключений (логирование / идентификация приложения у провайдера)
DATABASE_CONNECTION_CLIENT_NAME=prop-radar-evolution

# Evolution API — Redis-кэш (v2; см. doc.evolution-api.com).
# Инструкция: не включайте Redis в режиме «только tools». Сервис Redis — в docker/infra (propradar-redis).
# Включайте CACHE_REDIS_ENABLED=true только при совместном запуске: --profile infra и --profile tools
# (один и тот же проект compose из корня репозитория, сеть propradar).
# Дефолт ниже — безопасный для tools-only (без infra): приложение не ждёт и не требует Redis.
CACHE_REDIS_ENABLED=false
# URI Redis внутри Docker-сети (актуально при CACHE_REDIS_ENABLED=true и профиле infra)
CACHE_REDIS_URI=redis://propradar-redis:6379
# Префикс ключей при общей инстанции Redis
CACHE_REDIS_PREFIX_KEY=propradar-evolution
# Локальный кэш alongside Redis (обычно false, если Redis включён)
CACHE_LOCAL_ENABLED=false
# Хранить метаданные инстансов в Redis вместо только БД (true/false по политике деплоя)
CACHE_REDIS_SAVE_INSTANCES=false
# 2captcha API key
TWOCAPTCHA_API_KEY=
