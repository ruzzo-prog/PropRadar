# Профиль: сервер (контейнеры в сети propradar; БД только leads-db:5432 внутри сети).
# Скопируйте на сервер в корневой `.env` и/или используйте как шаблон для docker/*/.env.
# Не публикуйте порт PostgreSQL в интернет (0.0.0.0); см. docs/DEPLOY_SERVER.md и SSH-туннель для временного доступа с локальной машины.

# Из контейнеров api/parsers (docker/app):
DATABASE_URL=postgresql://leads:Melania2012!@leads-db:5432/leads

APP_ENV=production

# Совпадайте с POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB в docker/infra/.env на этом же хосте.

MYHOME_API_BASE_URL=https://api-statements.tnet.ge
MYHOME_INTEGRATION=0

# Обязательно задать в production при включённой проверке ключа API:
PROPRADAR_API_KEY=1070c85b1047ef76267777d7eb6fe847

# playwright-worker (корневой .env, env_file в docker/app/docker-compose.yml): автологин myhome — без реальных значений телефоны не парсятся.
MYHOME_EMAIL=user@example.com
MYHOME_PASSWORD=CHANGEME_STRONG_PASSWORD

# myhome / Metabase — по необходимости те же ключи, что и локально; секреты не коммитить.
