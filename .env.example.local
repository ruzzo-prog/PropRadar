# Профиль: локальная разработка (Windows / хост, БД в Docker на localhost:5433).
# Скопируйте в корневой `.env` и подставьте секреты. Не коммитить `.env`.

# PostgreSQL leads-db с хоста (docker/infra публикует 5433:5432)
DATABASE_URL=postgresql://leads:changeme@localhost:5433/leads

APP_ENV=development

# Локальный HTTP API (uvicorn на хосте) — порт 9000, см. README.md
# n8n в Docker обращается через http://host.docker.internal:9000 (Windows / Docker Desktop)

MYHOME_API_BASE_URL=https://api-statements.tnet.ge
MYHOME_INTEGRATION=0

# myhome.ge: scripts/myhome_login.py и run_myhome_enricher
# MYHOME_EMAIL=
# MYHOME_PASSWORD=
# MYHOME_SESSION_PATH=scripts/myhome_session.json
# MYHOME_ENRICH_LIMIT=50
# MYHOME_PDF_OUTPUT_DIR=data/myhome_pdf
# MYHOME_PDF_PUBLIC_BASE_URL=

# Metabase: scripts/setup_metabase_dashboard.py
# METABASE_URL=http://localhost:3031
# METABASE_USER=
# METABASE_PASSWORD=
# LEADS_DATABASE_NAME=PropRadar Leads
